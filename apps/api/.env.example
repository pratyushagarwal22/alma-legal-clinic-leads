# Copy to .env and fill in real values for local development.

# Database (used from Task 2 onward)
DATABASE_URL=postgresql+psycopg://legal:legal@localhost:5432/legal

# Auth / JWT (used from Task 8 onward)
JWT_SECRET=change-me

# Email / SMTP -> Mailpit (used from Task 7 onward)
SMTP_HOST=localhost
SMTP_PORT=1025

# Local file storage (used from Task 6 onward)
UPLOADS_DIR=./uploads

# Seed attorney user (used from Task 4 onward)
SEED_ATTORNEY_EMAIL=attorney@example.com
SEED_ATTORNEY_PASSWORD=change-me
